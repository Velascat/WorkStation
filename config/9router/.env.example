# =============================================================================
# 9router — Environment Variables
# Copy this file to .env (in the same directory) before starting the stack.
#
# Provider credentials are NOT configured here.
# Connect providers through the 9router dashboard at http://localhost:20128
# after the stack is running. Free options require no API keys:
#
#   Kiro    — free Claude Sonnet 4.5 via AWS Builder ID / GitHub OAuth
#   iFlow   — free Deepseek R1, Qwen3, GLM via OAuth
#   Qwen    — free Qwen3-Coder via device code auth
#   Gemini  — free Gemini 2.5 Pro via Google OAuth (quota-limited)
#   Ollama  — free local models, no account needed (install https://ollama.com)
# =============================================================================

# ── Required ──────────────────────────────────────────────────────────────────

# Secret used to sign JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# Password for the 9router dashboard (first-run admin account).
INITIAL_PASSWORD=change-me

# ── Optional ──────────────────────────────────────────────────────────────────

# Directory where 9router stores its database and provider credentials.
# Defaults to ~/.9router inside the container if not set.
# DATA_DIR=/app/data

# Port 9router binds to inside the container.
PORT=20128
HOSTNAME=0.0.0.0

# Disable Next.js telemetry.
NEXT_TELEMETRY_DISABLED=1

# =============================================================================
# WorkStation — Environment Variables
# Copy this file to .env and fill in values for your environment.
# Never commit .env to version control.
# =============================================================================

# ── SwitchBoard ──────────────────────────────────────────────────────────────
# Port that the SwitchBoard gateway listens on.
PORT_SWITCHBOARD=20401

# ── 9router ──────────────────────────────────────────────────────────────────
# Port that the 9router model dispatcher listens on.
PORT_9ROUTER=20128

# Internal URL WorkStation uses to reach 9router (used by SwitchBoard config).
NINE_ROUTER_URL=http://localhost:20128

# ── Status API ───────────────────────────────────────────────────────────────
# Port for the stack-level status / health aggregation endpoint.
PORT_STATUS=20400

# ── Compose project ──────────────────────────────────────────────────────────
# Optional: override the default compose project name.
# COMPOSE_PROJECT_NAME=workstation

# ── Logging ──────────────────────────────────────────────────────────────────
# Log level applied across services that honour it.
# LOG_LEVEL=info

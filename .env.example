# =============================================================================
# WorkStation — Environment Variables
# Copy this file to .env and fill in values for your environment.
# Never commit .env to version control.
# =============================================================================

# ── SwitchBoard ──────────────────────────────────────────────────────────────
# Port that the SwitchBoard gateway listens on.
PORT_SWITCHBOARD=20401

# ── Status API ───────────────────────────────────────────────────────────────
# Port for the stack-level status / health aggregation endpoint.
PORT_STATUS=20400

# ── Plane (optional) ─────────────────────────────────────────────────────────
# Set to "true" to have up.sh start Plane automatically.
# Plane is a task board used by ControlPlane. It is not required for
# SwitchBoard to operate. See scripts/plane.sh for manual lifecycle control.
# PLANE_ENABLED=false
# PLANE_URL=http://localhost:8080

# ── Compose project ──────────────────────────────────────────────────────────
# Optional: override the default compose project name.
# COMPOSE_PROJECT_NAME=workstation

# ── Logging ──────────────────────────────────────────────────────────────────
# Log level applied across services that honour it.
# LOG_LEVEL=info

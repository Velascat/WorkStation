# =============================================================================
# 9router — Environment Variables
# Copy this file to .env (in the same directory) before starting the stack.
# =============================================================================

# Port 9router binds to inside the container.
NINE_ROUTER_PORT=20128

# Log verbosity: debug | info | warn | error
NINE_ROUTER_LOG_LEVEL=info

# ── Provider credentials ──────────────────────────────────────────────────────
# Uncomment and fill in keys for each provider 9router should use.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# COHERE_API_KEY=...
# MISTRAL_API_KEY=...

# ── Provider selection strategy ───────────────────────────────────────────────
# Strategy 9router uses when multiple providers can serve a request.
# Options: round_robin | latency | cost | priority
# NINE_ROUTER_STRATEGY=latency

# ── Timeout (ms) ──────────────────────────────────────────────────────────────
# Maximum time to wait for a provider response before failing over.
# NINE_ROUTER_PROVIDER_TIMEOUT_MS=25000

# ── Retry ─────────────────────────────────────────────────────────────────────
# Number of provider retries on transient failure.
# NINE_ROUTER_RETRIES=2

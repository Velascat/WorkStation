# =============================================================================
# WorkStation — .gitignore
# =============================================================================

# ── Environment & secrets ────────────────────────────────────────────────────
.env
!.env.example
*.key
*.pem
*.p12
secrets/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.whl
pip-wheel-metadata/
.installed.cfg
MANIFEST
.Python
.venv/
venv/
env/
ENV/
.virtualenv/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytest_cache/
.tox/
.coverage
.coverage.*
coverage.xml
htmlcov/
nosetests.xml
*.log
*.pot

# ── Node / JavaScript ────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.yarn/
.pnp.*
.npm
.eslintcache
.parcel-cache
.next/
.nuxt/
dist/
.cache/
.turbo/

# ── Docker ───────────────────────────────────────────────────────────────────
docker-compose.override.yml
!docker-compose.override.example.yml

# ── OS ───────────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon

# Windows
Thumbs.db
Thumbs.db:encdata
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.nfs*

# ── Editors ──────────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── Logs & runtime ───────────────────────────────────────────────────────────
logs/
*.log
pids/
*.pid
*.seed
*.pid.lock
tmp/
temp/

# ── Config overrides (live copies, not examples) ─────────────────────────────
config/switchboard/policy.yaml
config/switchboard/profiles.yaml
config/9router/.env
config/workstation/endpoints.yaml

# FOB operator state
.fob/
!.fob/*.example*
config/workstation/services.yaml
config/workstation/ports.yaml
config/switchboard/capabilities.yaml

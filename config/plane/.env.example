# =============================================================================
# WorkStation — Plane configuration overrides
# Copy this file to .env (same directory) to override defaults.
#
# These variables control how WorkStation manages Plane.
# Generated runtime files (docker-compose.yaml, plane.env) are written to
# WorkStation/runtime/plane/ (gitignored) on first startup.
#
# Plane credential setup (workspace, API token, projects) is done through
# the Plane UI at http://localhost:8080 after first startup.
# =============================================================================

# Port Plane listens on (default: 8080)
# PLANE_PORT=8080

# URL Plane is reachable at (must match the port above)
# PLANE_URL=http://localhost:8080

# Pin to a specific Plane release tag (default: latest stable)
# PLANE_VERSION=v0.24.0

# Override the URL used to download Plane's setup.sh (advanced use)
# PLANE_SETUP_URL=https://github.com/makeplane/plane/releases/latest/download/setup.sh
